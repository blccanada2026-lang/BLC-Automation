// ── FACT table names — need a current-period partition tab ────
var FACT_TABLE_NAMES = [
  'FACT_JOB_EVENTS',
  'FACT_WORK_LOGS',
  'FACT_QC_EVENTS',
  'FACT_BILLING_LEDGER',
  'FACT_PAYROLL_LEDGER',
  'FACT_SOP_SUBMISSIONS'
];

// ============================================================
// INTERNAL HELPERS
// ============================================================

/**
 * Returns the active spreadsheet.
 * SetupScript always operates on the active spreadsheet —
 * no Config dependency, so it works before IDs are configured.
 */
function getss_() {
  return SpreadsheetApp.getActiveSpreadsheet();
}

/**
 * Returns current YYYY-MM period string.
 * Inline — does not depend on Identifiers.gs being loaded.
 */
function currentPeriod_() {
  var d   = new Date();
  var mm  = String(d.getMonth() + 1);
  if (mm.length < 2) mm = '0' + mm;
  return d.getFullYear() + '-' + mm;
}

/**
 * Logs a message to both the GAS execution log and the
 * script editor console. Prefixes with [Setup].
 */
function log_(message) {
  console.log('[Setup] ' + message);
}

/**
 * Returns the Sheet for tabName, or null if it doesn't exist.
 */
function getTab_(tabName) {
  return getss_().getSheetByName(tabName);
}

/**
 * Creates a sheet tab if it doesn't already exist.
 * Returns the Sheet object (existing or newly created).
 *
 * @param {string} tabName
 * @returns {Sheet}
 */
function ensureTab_(tabName) {
  var sheet = getTab_(tabName);
  if (sheet) {
    log_('  ✅ EXISTS   ' + tabName);
    return sheet;
  }
  sheet = getss_().insertSheet(tabName);
  log_('  ➕ CREATED  ' + tabName);
  return sheet;
}

/**
 * Writes the header row to a sheet if it has no rows yet.
 * Skips if row 1 already has content (preserves existing headers).
 *
 * @param {Sheet}    sheet
 * @param {string[]} headers
 */
function ensureHeaders_(sheet, headers) {
  if (sheet.getLastRow() > 0) return;  // already has content
  applyHeaders_(sheet, headers);
}

/**
 * Force-writes the header row to row 1 regardless of existing content.
 * Preserves all data rows (row 2+). Use runFixHeaders() to fix mismatched
 * headers on pre-existing sheets.
 *
 * @param {Sheet}    sheet
 * @param {string[]} headers
 */
function applyHeaders_(sheet, headers) {
  if (sheet.getLastRow() === 0) {
    sheet.appendRow(headers);
  } else {
    // Expand columns if needed before writing
    if (sheet.getLastColumn() < headers.length) {
      sheet.insertColumnsAfter(sheet.getLastColumn(),
        headers.length - sheet.getLastColumn());
    }
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  }
  sheet.setFrozenRows(1);
  var headerRange = sheet.getRange(1, 1, 1, headers.length);
  headerRange.setFontWeight('bold');
  headerRange.setBackground('#f3f3f3');
}

// ============================================================
// PHASE 1: SCHEMA SETUP
// Creates all tabs and writes header rows.
// ============================================================

/**
 * Creates all required sheet tabs and writes their header rows.
 * Idempotent — existing tabs and headers are not touched.
 */
function setupSchemas_() {
  log_('─────────────────────────────────────────');
  log_('PHASE 1: Sheet schemas');
  log_('─────────────────────────────────────────');

  var period = currentPeriod_();

  // ── Non-FACT tables (static tab names) ──────────────────
  var tableNames = Object.keys(SCHEMAS);
  for (var i = 0; i < tableNames.length; i++) {
    var tableName = tableNames[i];
    // FACT tables handled separately (with partition suffix)
    if (tableName.indexOf('FACT_') === 0) continue;

    var sheet = ensureTab_(tableName);
    ensureHeaders_(sheet, SCHEMAS[tableName]);
  }

  // ── FACT table partitions (current period) ───────────────
  log_('─────────────────────────────────────────');
  log_('FACT partitions for period: ' + period);
  log_('─────────────────────────────────────────');

  for (var j = 0; j < FACT_TABLE_NAMES.length; j++) {
    var factTable  = FACT_TABLE_NAMES[j];
    var tabName    = factTable + '|' + period;
    var factSheet  = ensureTab_(tabName);
    ensureHeaders_(factSheet, SCHEMAS[factTable]);
  }

  log_('Schema setup complete.');
}

// ============================================================
// PHASE 2: SEED DATA
// Inserts required reference rows that must exist before
// the system can process its first job.
// ============================================================

/**
 * Seeds DIM_SEQUENCE_COUNTERS with the JOB_NUMBER counter
 * if it doesn't already exist.
 */
function seedSequenceCounters_() {
  log_('Seeding DIM_SEQUENCE_COUNTERS…');
  var sheet = getTab_('DIM_SEQUENCE_COUNTERS');
  if (!sheet) {
    log_('  ⚠️  DIM_SEQUENCE_COUNTERS tab not found — run schema setup first.');
    return;
  }

  // Check if JOB_NUMBER row already exists
  var lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    var existing = sheet.getRange(2, 1, lastRow - 1, 1).getValues();
    for (var i = 0; i < existing.length; i++) {
      if (existing[i][0] === 'JOB_NUMBER') {
        log_('  ✅ JOB_NUMBER counter already exists (current_value = ' +
             sheet.getRange(i + 2, 2).getValue() + ')');
        return;
      }
    }
  }

  // Insert seed row
  sheet.appendRow(['JOB_NUMBER', 0, new Date().toISOString()]);
  log_('  ➕ JOB_NUMBER counter seeded at 0');
}

/**
 * Seeds _SYS_VERSION with the current system version.
 */
function seedVersion_() {
  log_('Seeding _SYS_VERSION…');
  var sheet = getTab_('_SYS_VERSION');
  if (!sheet) {
    log_('  ⚠️  _SYS_VERSION tab not found — run schema setup first.');
    return;
  }

  var version = typeof Config !== 'undefined' ? Config.VERSION : '3.0.0';
  sheet.appendRow([
    version,
    new Date().toISOString(),
    Session.getActiveUser().getEmail(),
    'Initial setup via SetupScript.gs'
  ]);
  log_('  ➕ Version ' + version + ' recorded');
}

/**
 * Seeds all required reference data.
 * Safe to re-run — checks before inserting.
 */
function seedData_() {
  log_('─────────────────────────────────────────');
  log_('PHASE 2: Seed data');
  log_('─────────────────────────────────────────');

  seedSequenceCounters_();
  seedVersion_();

  log_('Seed data complete.');
  log_('');
  log_('Next steps:');
  log_('  1. Add staff rows to DIM_STAFF_ROSTER');
  log_('  2. Add client rows to DIM_CLIENT_MASTER');
  log_('  3. Add product rates to DIM_PRODUCT_RATES');
  log_('  4. Update Config.gs SPREADSHEET_IDS.DEV with this spreadsheet\'s ID');
  log_('  5. Run Triggers.gs to set up time-based trigger');
}

// ============================================================
// PHASE 3: VERIFY
// Checks all expected tabs exist and reports status.
// ============================================================

/**
 * Verifies all required tabs exist. Logs ✅ or ❌ for each.
 * Does not create or modify anything.
 */
function runVerify() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus — Setup Verification');
  log_('═════════════════════════════════════════');

  var period   = currentPeriod_();
  var allPass  = true;

  // Static tables
  var tableNames = Object.keys(SCHEMAS);
  for (var i = 0; i < tableNames.length; i++) {
    var name = tableNames[i];
    if (name.indexOf('FACT_') === 0) continue;
    if (getTab_(name)) {
      log_('✅  ' + name);
    } else {
      log_('❌  ' + name + '  ← MISSING');
      allPass = false;
    }
  }

  // FACT partitions
  for (var j = 0; j < FACT_TABLE_NAMES.length; j++) {
    var tabName = FACT_TABLE_NAMES[j] + '|' + period;
    if (getTab_(tabName)) {
      log_('✅  ' + tabName);
    } else {
      log_('❌  ' + tabName + '  ← MISSING');
      allPass = false;
    }
  }

  // Sequence counter
  var seqSheet = getTab_('DIM_SEQUENCE_COUNTERS');
  if (seqSheet && seqSheet.getLastRow() > 1) {
    log_('✅  JOB_NUMBER sequence counter seeded');
  } else {
    log_('❌  JOB_NUMBER sequence counter missing  ← run runSetupSeedData()');
    allPass = false;
  }

  log_('─────────────────────────────────────────');
  log_(allPass ? '✅ All checks passed — system ready.' : '❌ Issues found — run runSetup() to fix.');
  log_('═════════════════════════════════════════');
}

// ============================================================
// PUBLIC ENTRY POINTS
// These are the functions visible in the Apps Script editor.
// ============================================================

/**
 * FULL SETUP — run this on first deployment.
 * Creates all sheet tabs, writes headers, seeds reference data.
 * Safe to re-run at any time.
 */
function runSetup() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus V' +
       (typeof Config !== 'undefined' ? Config.VERSION : '3.0.0') +
       ' — Full Setup');
  log_('Spreadsheet: ' + SpreadsheetApp.getActiveSpreadsheet().getName());
  log_('Run by: ' + Session.getActiveUser().getEmail());
  log_('═════════════════════════════════════════');

  setupSchemas_();
  seedData_();

  log_('═════════════════════════════════════════');
  log_('Setup complete. Run runVerify() to confirm.');
  log_('═════════════════════════════════════════');
}

/**
 * SCHEMAS ONLY — creates tabs and headers without touching data.
 * Use after adding a new table to SCHEMAS.
 */
function runSetupSchemas() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus — Schema Setup Only');
  log_('═════════════════════════════════════════');
  setupSchemas_();
  log_('Done.');
}

/**
 * SEED DATA ONLY — inserts reference rows without touching tabs.
 * Use if schemas already exist but seed data is missing.
 */
function runSetupSeedData() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus — Seed Data Only');
  log_('═════════════════════════════════════════');
  seedData_();
  log_('Done.');
}

/**
 * FORCE-FIX HEADERS — rewrites row 1 on all tables to match the
 * current SCHEMAS definition. Use when a sheet existed before setup
 * ran and has wrong/old column headers.
 *
 * SAFE: only overwrites row 1. Data rows (row 2+) are untouched.
 * Run runVerify() afterwards to confirm.
 */
function runFixHeaders() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus — Force Fix Headers');
  log_('═════════════════════════════════════════');

  var period = currentPeriod_();

  // Fix all non-FACT tables
  var tableNames = Object.keys(SCHEMAS);
  for (var i = 0; i < tableNames.length; i++) {
    var tableName = tableNames[i];
    if (tableName.indexOf('FACT_') === 0) continue;

    var sheet = getTab_(tableName);
    if (!sheet) {
      log_('  ⚠️  MISSING: ' + tableName + ' — run runSetupSchemas() first');
      continue;
    }
    applyHeaders_(sheet, SCHEMAS[tableName]);
    log_('  ✅ FIXED: ' + tableName);
  }

  // Fix FACT partition tabs for current period
  for (var j = 0; j < FACT_TABLE_NAMES.length; j++) {
    var tabName   = FACT_TABLE_NAMES[j] + '|' + period;
    var factSheet = getTab_(tabName);
    if (!factSheet) {
      log_('  ⚠️  MISSING: ' + tabName + ' — run runSetupSchemas() first');
      continue;
    }
    applyHeaders_(factSheet, SCHEMAS[FACT_TABLE_NAMES[j]]);
    log_('  ✅ FIXED: ' + tabName);
  }

  log_('Header fix complete. Run runVerify() to confirm.');
  log_('═════════════════════════════════════════');
}
