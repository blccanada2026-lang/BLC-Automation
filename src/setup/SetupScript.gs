    'account_number', 'account_type',
    'ifsc_code',          // India — 11-character bank branch code
    'swift_bic',          // International — 8 or 11 characters
    'iban',               // Europe / Middle East
    'routing_number',     // USA (9-digit ABA)
    'institution_number', // Canada (3-digit)
    'transit_number',     // Canada (5-digit)
    'currency', 'purpose_of_payment',
    'ofx_recipient_id',   // OFX platform recipient ID (fill after adding to OFX)
