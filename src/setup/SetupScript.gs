// ============================================================
// PHASE 3: VERIFY
// Checks all expected tabs exist and reports status.
// ============================================================

/**
 * Verifies all required tabs exist. Logs ✅ or ❌ for each.
 * Does not create or modify anything.
 */
function runVerify() {
  log_('═════════════════════════════════════════');
  log_('BLC Nexus — Setup Verification');
  log_('═════════════════════════════════════════');

  var period   = currentPeriod_();
  var allPass  = true;

  // Static tables
  var tableNames = Object.keys(SCHEMAS);
  for (var i = 0; i < tableNames.length; i++) {
    var name = tableNames[i];
    if (name.indexOf('FACT_') === 0) continue;
    if (getTab_(name)) {
      log_('✅  ' + name);
    } else {
      log_('❌  ' + name + '  ← MISSING');
      allPass = false;
    }
  }

  // FACT partitions
  for (var j = 0; j < FACT_TABLE_NAMES.length; j++) {
    var tabName = FACT_TABLE_NAMES[j] + '|' + period;
    if (getTab_(tabName)) {
      log_('✅  ' + tabName);
    } else {
      log_('❌  ' + tabName + '  ← MISSING');
      allPass = false;
    }
  }

  // Sequence counter
  var seqSheet = getTab_('DIM_SEQUENCE_COUNTERS');
  if (seqSheet && seqSheet.getLastRow() > 1) {
    log_('✅  JOB_NUMBER sequence counter seeded');
  } else {
    log_('❌  JOB_NUMBER sequence counter missing  ← run runSetupSeedData()');
    allPass = false;
  }

  log_('─────────────────────────────────────────');
  log_(allPass ? '✅ All checks passed — system ready.' : '❌ Issues found — run runSetup() to fix.');
  log_('═════════════════════════════════════════');
}

